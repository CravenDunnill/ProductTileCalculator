<?php
/**
 * CravenDunnill ProductTileCalculator Extension - Cart Item Renderer
 *
 * @var $block \Magento\Checkout\Block\Cart\Item\Renderer
 * @var \CravenDunnill\ProductTileCalculator\ViewModel\ProductAttributeViewModel $attributeViewModel
 */

$attributeViewModel = $block->getData('product_attribute_view_model');
$item = $block->getItem();
$product = $item->getProduct();
$productId = $product->getId();
?>

<div class="cart-item-details-container">
	<?php echo $block->getItemHtml($item); ?>
	
	<?php if ($attributeViewModel): ?>
		<div class="tile-details-cart">
			<div class="tile-details-item">
				<span class="tile-details-label"><?= $block->escapeHtml(__('Product Type:')) ?></span>
				<span class="tile-details-value"><?= $block->escapeHtml($attributeViewModel->getAttributeSetName($productId)) ?></span>
			</div>
			
			<?php 
			$colourValue = $attributeViewModel->getAttributeText($productId, 'tile_colour_name');
			if ($colourValue): 
			?>
			<div class="tile-details-item">
				<span class="tile-details-label"><?= $block->escapeHtml(__('Colour:')) ?></span>
				<span class="tile-details-value"><?= $block->escapeHtml($colourValue) ?></span>
			</div>
			<?php endif; ?>
			
			<?php 
			$sizeValue = $attributeViewModel->getAttributeText($productId, 'tile_size');
			if ($sizeValue): 
			?>
			<div class="tile-details-item">
				<span class="tile-details-label"><?= $block->escapeHtml(__('Size:')) ?></span>
				<span class="tile-details-value"><?= $block->escapeHtml($sizeValue) ?></span>
			</div>
			<?php endif; ?>
			
			<?php 
			$boxQuantity = $attributeViewModel->getAttributeValue($productId, 'box_quantity');
			?>
			<div class="tile-details-item">
				<span class="tile-details-label"><?= $block->escapeHtml(__('Tiles per Box:')) ?></span>
				<span class="tile-details-value"><?= $block->escapeHtml($boxQuantity ?: 'N/A') ?></span>
			</div>
			
			<div class="tile-details-item">
				<span class="tile-details-label"><?= $block->escapeHtml(__('Total Tiles:')) ?></span>
				<span class="tile-details-value"><?= $block->escapeHtml($item->getQty()) ?></span>
			</div>
			
			<?php 
			$tilePerM2 = $attributeViewModel->getAttributeValue($productId, 'tile_per_m2');
			if ($tilePerM2 && $boxQuantity): 
				$areaCoverage = $item->getQty() / $tilePerM2;
			?>
			<div class="tile-details-item">
				<span class="tile-details-label"><?= $block->escapeHtml(__('Coverage:')) ?></span>
				<span class="tile-details-value"><?= $block->escapeHtml(number_format($areaCoverage, 2) . ' m²') ?></span>
			</div>
			<?php endif; ?>
		</div>
	<?php endif; ?>
</div>