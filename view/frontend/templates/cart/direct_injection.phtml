<?php
/**
 * CravenDunnill ProductTileCalculator Extension - Direct cart injection
 *
 * @var $block \Magento\Framework\View\Element\Template
 */

// Get the attribute view model if available
$attributeViewModel = $block->getData('product_attribute_view_model');

// Load the calculator helper
$objectManager = \Magento\Framework\App\ObjectManager::getInstance();
$calculatorHelper = $objectManager->get(\CravenDunnill\ProductTileCalculator\Helper\Calculator::class);
$productRepository = $objectManager->get(\Magento\Catalog\Api\ProductRepositoryInterface::class);
$cartItems = [];

// Debug all cart items
$checkoutSession = $objectManager->get(\Magento\Checkout\Model\Session::class);
if ($checkoutSession) {
	$quote = $checkoutSession->getQuote();
	if ($quote) {
		error_log("Cart contains " . count($quote->getAllVisibleItems()) . " visible items");
		
		foreach ($quote->getAllVisibleItems() as $item) {
			try {
				// Get basic product info first
				$productId = $item->getProductId();
				$sku = $item->getSku();
				error_log("Processing cart item: Product ID={$productId}, SKU={$sku}, Name={$item->getName()}");
				
				// Load full product data with all attributes
				$product = $productRepository->getById($productId);
				error_log("Product loaded successfully: " . $product->getName());
				
				// Get some basic data
				error_log("Product Type ID: " . $product->getTypeId());
				error_log("Attribute Set ID: " . $product->getAttributeSetId());
				
				// Try loading all needed attributes directly
				error_log("box_quantity (direct): " . $product->getData('box_quantity'));
				error_log("tile_per_m2 (direct): " . $product->getData('tile_per_m2'));
				error_log("price_m2 (direct): " . $product->getData('price_m2'));
				
				// Check if calculator helper thinks it can use calculator
				$canUseCalc = $calculatorHelper->canUseCalculator($product);
				error_log("Can use calculator: " . ($canUseCalc ? 'YES' : 'NO'));
				
				// Continue with regular processing
				if ($product) {
					// Explicitly get box_quantity - use helper as primary source
					$boxQuantity = $calculatorHelper->getBoxQuantity($product);
					error_log("box_quantity (from helper): " . $boxQuantity);
					
					// Fallback if helper returns default value (1)
					if ($boxQuantity <= 1) {
						// Try direct access
						$boxQuantity = $product->getData('box_quantity');
						error_log("box_quantity (from fallback): " . $boxQuantity);
					}
					
					$tilePerM2 = $calculatorHelper->getTilePerM2($product);
					error_log("tilePerM2 (from helper): " . $tilePerM2);
					
					// Get color directly from product attribute
					$colorValue = '';
					try {
						$colorValue = $product->getAttributeText('tile_colour_name');
						if (empty($colorValue)) {
							$colorValue = $product->getData('tile_colour_name');
						}
						error_log("colorValue: " . $colorValue);
					} catch (\Exception $e) {
						$colorValue = $product->getData('tile_colour_name');
						error_log("colorValue (from fallback): " . $colorValue);
					}
					
					// Get size directly from product attribute
					$sizeValue = '';
					try {
						$sizeValue = $product->getAttributeText('tile_size');
						if (empty($sizeValue)) {
							$sizeValue = $product->getData('tile_size');
						}
						error_log("sizeValue: " . $sizeValue);
					} catch (\Exception $e) {
						$sizeValue = $product->getData('tile_size');
						error_log("sizeValue (from fallback): " . $sizeValue);
					}
					
					// Get attribute set name using ViewModel when available
					$attributeSetName = '';
					if ($attributeViewModel) {
						$attributeSetName = $attributeViewModel->getAttributeSetName($productId);
						error_log("Attribute set name from ViewModel: " . $attributeSetName);
					} else {
						// Fallback to direct repository approach
						try {
							$attributeSetId = $product->getAttributeSetId();
							if ($attributeSetId) {
								$attributeSetRepository = $objectManager->get(\Magento\Eav\Api\AttributeSetRepositoryInterface::class);
								$attributeSet = $attributeSetRepository->get($attributeSetId);
								$attributeSetName = $attributeSet->getAttributeSetName();
								error_log("Attribute set name from fallback: " . $attributeSetName);
							}
						} catch (\Exception $e) {
							error_log("Error getting attribute set: " . $e->getMessage());
						}
					}
					
					// Add the data to our cart items array regardless of calculator results
					$cartItems[$productId] = [
						'boxQuantity' => $boxQuantity,
						'tilePerM2' => $tilePerM2,
						'attributeSetName' => $attributeSetName,
						'colorValue' => $colorValue,
						'sizeValue' => $sizeValue,
						'canUseCalculator' => $canUseCalc
					];
				}
			} catch (\Exception $e) {
				error_log("Error processing product: " . $e->getMessage());
			}
		}
	}
}

// Log the final data structure
error_log("Final cartItems data: " . json_encode($cartItems));
?>

<script>
// Product data from Magento
var tileProductData = <?= json_encode($cartItems) ?>;

require(['jquery', 'domReady!'], function($) {
	'use strict';
	
	// Function to calculate m² from boxes
	function calculateM2FromBoxes(boxes, tilesPerBox, tilesPerM2) {
		const tilesInBoxes = boxes * tilesPerBox;
		return tilesInBoxes / tilesPerM2;
	}
	
	// Function to create or update tile details
	function updateTileDetails($cartItem, forceCreate) {
		const $productDetails = $cartItem.find('.product-item-details');
		const $productName = $productDetails.find('.product-item-name');
		const $qtyInput = $cartItem.find('input[data-role="cart-item-qty"], input.qty');
		
		// Skip if no product details found
		if ($productDetails.length === 0 || $qtyInput.length === 0) {
			console.log("Missing required DOM elements, skipping");
			return;
		}
		
		const itemId = $qtyInput.attr('id')?.replace('cart-', '').replace('-qty', '') || '';
		const tilesQty = parseInt($qtyInput.val()) || 1;
		console.log("Processing item ID: " + itemId + ", qty: " + tilesQty);
		
		// Variables to hold our product data
		let boxQty = null;
		let tilesPerM2 = null;
		let attributeSetName = '';
		let colour = '';
		let size = '';
		
		// Find the product ID from data attributes
		let productId = $qtyInput.data('product-id') || itemId;
		
		// Try to get product ID from the cart item
		if (!tileProductData[productId]) {
			console.log("Product ID " + productId + " not found in data, trying alternatives");
			
			// Try from item-id data attribute 
			const dataItemId = $cartItem.data('item-id');
			if (dataItemId) {
				productId = dataItemId;
				console.log("Found product ID from data-item-id: " + productId);
			}
			
			// Try from url in name
			const $nameLink = $productName.find('a');
			if ($nameLink.length > 0) {
				const href = $nameLink.attr('href');
				const idMatch = href && href.match(/\/([0-9]+)$/);
				if (idMatch && idMatch[1]) {
					productId = idMatch[1];
					console.log("Found product ID from URL: " + productId);
				}
			}
		}
		
		// Log all item IDs in our data for debugging
		console.log("Available product IDs in data:", Object.keys(tileProductData));
		
		// Look for matching data in our PHP-generated object
		if (tileProductData[productId]) {
			console.log("Found product data for ID: " + productId, tileProductData[productId]);
			boxQty = parseInt(tileProductData[productId].boxQuantity);
			tilesPerM2 = parseFloat(tileProductData[productId].tilePerM2);
			attributeSetName = tileProductData[productId].attributeSetName;
			colour = tileProductData[productId].colorValue;
			size = tileProductData[productId].sizeValue;
			
			console.log("Using data: BoxQty=" + boxQty + ", TilesPerM2=" + tilesPerM2);
		} else {
			console.log("Product data not found for ID: " + productId + ", trying DOM data");
			
			// Try to find product data in the DOM
			const $boxQtyElem = $cartItem.find('[data-box-qty]');
			if ($boxQtyElem.length > 0) {
				boxQty = parseInt($boxQtyElem.data('box-qty'));
				console.log("Found box qty in DOM: " + boxQty);
			} else {
				// Set a basic value as last resort
				boxQty = 1;
				console.log("Using placeholder box qty: 1");
			}
			
			// Try to extract from product name as fallback
			const productName = $productName.text().trim();
			console.log("Product name: " + productName);
			
			const colourMatch = productName.match(/^([^-]+)/);
			colour = colourMatch ? colourMatch[1].trim() : '';
			
			const sizeMatch = productName.match(/- ([^-]+)$/);
			size = sizeMatch ? sizeMatch[1].trim() : '';
		}
		
		// Calculate area coverage based on total tiles and tiles per m²
		const totalTiles = tilesQty; // Keep original total
		let areaCoverage = 0;
		
		if (tilesPerM2 && tilesPerM2 > 0) {
			areaCoverage = totalTiles / tilesPerM2;
			console.log("Calculated coverage: " + areaCoverage.toFixed(3) + " m²");
		} else {
			console.log("Cannot calculate coverage: tilesPerM2 = " + tilesPerM2);
		}
		
		// Create or update the details
		let $tileDetails = $productDetails.find('.tile-details-cart');
		
		if ($tileDetails.length === 0 || forceCreate) {
			// Create new details element
			if ($tileDetails.length > 0) {
				$tileDetails.remove(); // Remove existing one if we're forcing recreation
			}
			
			const detailsHtml = `
				<div class="tile-details-cart" id="tile-details-${itemId}">
					<div class="tile-details-item">
						<span class="tile-details-label">Product Type:</span>
						<span class="tile-details-value">${attributeSetName || 'Default'}</span>
					</div>
					${colour ? `
					<div class="tile-details-item">
						<span class="tile-details-label">Colour:</span>
						<span class="tile-details-value">${colour}</span>
					</div>
					` : ''}
					${size ? `
					<div class="tile-details-item">
						<span class="tile-details-label">Size:</span>
						<span class="tile-details-value">${size}</span>
					</div>
					` : ''}
					<div class="tile-details-item">
						<span class="tile-details-label">Tiles per Box:</span>
						<span class="tile-details-value">${boxQty || 'N/A'}</span>
					</div>
					<div class="tile-details-item">
						<span class="tile-details-label">Total Tiles:</span>
						<span class="tile-details-value tile-total-qty">${tilesQty}</span>
					</div>
					${tilesPerM2 && tilesPerM2 > 0 ? `
					<div class="tile-details-item">
						<span class="tile-details-label">Coverage:</span>
						<span class="tile-details-value tile-area-coverage">${areaCoverage.toFixed(3)} m<sup>2</sup></span>
					</div>
					` : ''}
				</div>
			`;
			
			// Insert right after the product name
			$productName.after(detailsHtml);
			
			console.log("Created tile details for product ID: " + itemId);
			
			// Replace native quantity field with box-based controls
			//addBoxControls($cartItem, boxQty, tilesQty);
		} else {
			// Update existing values
			$tileDetails.find('.tile-total-qty').text(tilesQty);
			
			const $coverageElem = $tileDetails.find('.tile-area-coverage');
			if ($coverageElem.length > 0 && tilesPerM2 > 0) {
				$coverageElem.html(`${areaCoverage.toFixed(3)} m<sup>2</sup>`);
			}
			
			// Update attribute set name if element exists
			const $attributeSetRow = $tileDetails.find('.tile-details-item:first-child .tile-details-value');
			if ($attributeSetRow.length > 0) {
				$attributeSetRow.text(attributeSetName || 'Default');
			}
			
			console.log(`Updated tile details for product ID: ${itemId}`);
		}
		
		// Update box info display if it exists
		const $boxInfo = $cartItem.find('.box-info');
		if ($boxInfo.length > 0 && boxQty > 0) {
			const boxes = Math.floor(tilesQty / boxQty) || 1;
			const boxText = boxes === 1 ? 'box' : 'boxes';
			$boxInfo.find('.box-qty-display').text(`${boxes} ${boxText}`);
			
			if (tilesPerM2 > 0) {
				$boxInfo.find('.area-display').text(`(${areaCoverage.toFixed(3)} m²)`);
			}
		}
	}
	
	// Function to inject tile details for all cart items
	function injectTileDetails(forceCreate) {
		console.log('Direct injection: Processing cart items');
		
		// Find all cart items
		$('.cart.item').each(function() {
			updateTileDetails($(this), forceCreate);
		});
	}
	
	// Execute on page load
	$(document).ready(function() {
		// Add styles for compact controls
		$('head').append(`
			<style>
				/* Compact quantity input styling */
				.control.qty.compact-controls {
					display: flex !important;
					max-width: 80px !important;
					position: relative !important;
				}

				.compact-controls .input-text.qty {
					width: 40px !important;
					text-align: center !important;
					border-radius: 4px !important;
					height: 34px !important;
					margin: 0 !important;
					padding: 0 3px !important;
				}

				.compact-controls .qty-changer {
					display: flex !important;
					flex-direction: column !important;
					height: 34px !important;
					position: absolute !important;
					right: 1px !important;
					top: 0 !important;
				}

				.compact-controls .action.plus,
				.compact-controls .action.minus {
					width: 16px !important;
					height: 17px !important;
					background: #002C5A !important;
					border: none !important;
					color: white !important;
					cursor: pointer !important;
					padding: 0 !important;
					margin: 0 !important;
					display: flex !important;
					align-items: center !important;
					justify-content: center !important;
					font-size: 8px !important;
					border-radius: 0 !important;
				}

				.compact-controls .action.plus {
					border-radius: 0 4px 0 0 !important;
				}

				.compact-controls .action.minus {
					border-radius: 0 0 4px 0 !important;
				}

				.compact-controls .action.plus:hover,
				.compact-controls .action.minus:hover {
					background: #001c38 !important;
				}
				
				/* Hide number input spinners */
				.compact-controls input[type=number]::-webkit-inner-spin-button, 
				.compact-controls input[type=number]::-webkit-outer-spin-button { 
					-webkit-appearance: none !important;
					margin: 0 !important;
				}
				.compact-controls input[type=number] {
					-moz-appearance: textfield !important;
				}
			</style>
		`);
		
		// Initial injection
		injectTileDetails(true);
		
		// Also run after a delay to ensure all elements are loaded
		setTimeout(function() { injectTileDetails(true); }, 1000);
	});
});
</script>