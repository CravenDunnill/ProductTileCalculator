<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
	<head>
		<css src="CravenDunnill_ProductTileCalculator::css/cart_calculator.css"/>
	</head>
	<body>
		<!-- Direct CSS injection to ensure styles are applied -->
		<referenceContainer name="before.body.end">
			<block class="Magento\Framework\View\Element\Template" 
				   name="cart.direct.css" 
				   template="CravenDunnill_ProductTileCalculator::cart/direct_css.phtml" />
		</referenceContainer>
		
		<!-- Direct injection script to add tile details -->
		<referenceContainer name="content">
			<block class="Magento\Framework\View\Element\Template" 
				   name="cart.direct.injection.script" 
				   template="CravenDunnill_ProductTileCalculator::cart/direct_injection.phtml"
				   after="-">
				<arguments>
					<argument name="product_attribute_view_model" xsi:type="object">CravenDunnill\ProductTileCalculator\ViewModel\ProductAttributeViewModel</argument>
				</arguments>
			</block>
				   
			<block class="Magento\Framework\View\Element\Template" 
				   name="cart.calculator.js" 
				   template="CravenDunnill_ProductTileCalculator::cart/calculator_js.phtml" 
				   after="-" />
				   
			<!-- New: Add box price update script -->
			<block class="Magento\Framework\View\Element\Template" 
				   name="cart.box.price.js" 
				   template="CravenDunnill_ProductTileCalculator::cart/box_price_js.phtml" 
				   after="-" />
		</referenceContainer>

		<!-- Add custom renderer for cart items -->
		<referenceBlock name="checkout.cart.item.renderers">
			<block class="Magento\Checkout\Block\Cart\Item\Renderer" name="checkout.cart.item.renderers.default.product.attribute" template="CravenDunnill_ProductTileCalculator::cart/item/renderer.phtml" as="default">
				<arguments>
					<argument name="product_attribute_view_model" xsi:type="object">CravenDunnill\ProductTileCalculator\ViewModel\ProductAttributeViewModel</argument>
				</arguments>
			</block>
			<block class="Magento\Checkout\Block\Cart\Item\Renderer" name="checkout.cart.item.renderers.simple.product.attribute" template="CravenDunnill_ProductTileCalculator::cart/item/renderer.phtml" as="simple">
				<arguments>
					<argument name="product_attribute_view_model" xsi:type="object">CravenDunnill\ProductTileCalculator\ViewModel\ProductAttributeViewModel</argument>
				</arguments>
			</block>
		</referenceBlock>
	</body>
</page>